# Aliyun EMAS Configuration
ALIYUN_ACCESS_KEY_ID=your_access_key_id_here
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret_here
ALIYUN_REGION=cn-shanghai

# EMAS App Configuration
EMAS_APP_KEY=your_app_key_here
EMAS_APP_PACKAGE_NAME=com.example.app
EMAS_CONSOLE_BASE_URL=https://emas.console.aliyun.com

# GitLab Configuration
GITLAB_BASE_URL=https://git.example.com
GITLAB_TOKEN=your_gitlab_token_here

# LLM Configuration (e.g., Zhipu GLM)
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_CHAT_COMPLETIONS_PATH=chat/completions
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=glm-4.6v

# Note: Copy this file to .env.local and fill in actual values
# .env.local is in .gitignore and should never be committed
