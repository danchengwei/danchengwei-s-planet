{
  "name": "web-pet",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "一个网页电子宠物 Chrome 扩展，基于 hunyuan-lite",
  "scripts": {
    "gen:icons": "node scripts/gen-icons.mjs",
    "dev": "npm run gen:icons && vite",
