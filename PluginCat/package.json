    "preview": "vite preview",
    "pack": "npm run build && cd dist && zip -r ../web-pet.zip ."
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
    "@types/chrome": "^0.0.268",
    "sharp": "^0.34.5",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  },
  "dependencies": {
    "@esotericsoftware/spine-pixi-v8": "^4.2.114",
    "pixi.js": "^8.0.0"
  }
}
